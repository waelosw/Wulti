-- Trouve le Gun Locker dans workspace/Lockers
local function findGunLocker()
   local lockers = workspace:FindFirstChild("Lockers")
   if lockers then
       for _, child in ipairs(lockers:GetChildren()) do
           if child.Name == "Gun Locker" then return child end
       end
   end
   for _, obj in ipairs(workspace:GetDescendants()) do
       if obj.Name == "Gun Locker" then return obj end
   end
   return nil
end

-- Trouve la crafting station : cherche n'importe quel objet dont le nom
-- commence par "Meshes/craftingstation4_Cube" et remonte au Model parent
local function findCraftingStation()
   local prefix = "Meshes/craftingstation4_Cube"
   for _, obj in ipairs(workspace:GetDescendants()) do
       if string.sub(obj.Name, 1, #prefix) == prefix then
           -- Remonte jusqu'à trouver un Model
           local current = obj.Parent
           while current and current ~= workspace do
               if current:IsA("Model") then
                   return current
               end
               current = current.Parent
           end
           -- Fallback : parent direct
           return obj.Parent
       end
   end
   return nil
end

-- Trouve les deux objets "Prizes" (remonte au Model parent)
local function findPrizes()
   local found = {}
   for _, obj in ipairs(workspace:GetDescendants()) do
       if obj.Name == "Prizes" then
           -- Remonte au Model parent
           local current = obj.Parent
           local target = obj
           while current and current ~= workspace do
               if current:IsA("Model") then
                   target = current
                   break
               end
               current = current.Parent
           end
           -- Évite les doublons
           local alreadyIn = false
           for _, v in ipairs(found) do
               if v == target then alreadyIn = true; break end
           end
           if not alreadyIn then
               table.insert(found, target)
           end
           if #found >= 2 then break end
       end
   end
   return found[1], found[2]
end

local function findFloor()
   for _, obj in ipairs(workspace:GetDescendants()) do
       if obj:IsA("BasePart") and obj.Name == "Part" then
           local s = obj.Size
           if math.abs(s.X - 42.3) < 0.5 and
              math.abs(s.Y - 2) < 0.5 and
              math.abs(s.Z - 72.651) < 0.5 then
               return obj
           end
       end
   end
   return nil
end

local function findInItemsOnSale(name)
   local itemsOnSale = workspace:FindFirstChild("ItemsOnSale", true)
   if not itemsOnSale then
       for _, obj in ipairs(workspace:GetDescendants()) do
           if obj.Name == name then return obj end
       end
       return nil
   end
   for _, obj in ipairs(itemsOnSale:GetChildren()) do
       if obj.Name == name then return obj end
   end
   return nil
end

local function getObjectCFrame(obj)
   if obj:IsA("Model") then
       if obj.PrimaryPart then return obj.PrimaryPart.CFrame end
       for _, p in ipairs(obj:GetDescendants()) do
           if p:IsA("BasePart") then return p.CFrame end
       end
   elseif obj:IsA("BasePart") then
       return obj.CFrame
   end
   return nil
end

local function moveWeapon(obj, position)
   local lookDir = (position - center)
   if lookDir.Magnitude > 0 then lookDir = lookDir.Unit end
   local cf = CFrame.new(position, position + lookDir)

   if obj:IsA("Model") then
       if obj.PrimaryPart then
           obj:SetPrimaryPartCFrame(cf)
       else
           for _, part in ipairs(obj:GetDescendants()) do
               if part:IsA("BasePart") then
                   local offset = position - part.Position
                   for _, p in ipairs(obj:GetDescendants()) do
                       if p:IsA("BasePart") then
                           p.CFrame = CFrame.new(p.Position + offset, p.Position + offset + lookDir)
                       end
                   end
                   break
               end
           end
       end
   elseif obj:IsA("BasePart") then
       obj.CFrame = cf
   end
end

-- Déplace un objet (Model ou BasePart) vers une position cible
-- extraRotY : rotation Y supplémentaire en radians (optionnel)
local function moveObject(obj, targetPos, extraRotY)
   extraRotY = extraRotY or 0
   if obj:IsA("Model") then
       if obj.PrimaryPart then
           local cf = obj.PrimaryPart.CFrame
           local rx, ry, rz = cf:ToEulerAnglesXYZ()
           obj:SetPrimaryPartCFrame(CFrame.new(targetPos) * CFrame.Angles(rx, ry + extraRotY, rz))
       else
           local firstPart = nil
           for _, p in ipairs(obj:GetDescendants()) do
               if p:IsA("BasePart") then firstPart = p; break end
           end
           if firstPart then
               local offset = targetPos - firstPart.Position
               for _, p in ipairs(obj:GetDescendants()) do
                   if p:IsA("BasePart") then
                       p.CFrame = CFrame.new(p.Position + offset)
                   end
               end
           end
       end
   elseif obj:IsA("BasePart") then
       obj.CFrame = CFrame.new(targetPos) * CFrame.Angles(0, extraRotY, 0)
   end
end

local function restoreWeapon(obj, cf)
   if obj:IsA("Model") then
       if obj.PrimaryPart then
           obj:SetPrimaryPartCFrame(cf)
       else
           for _, part in ipairs(obj:GetDescendants()) do
               if part:IsA("BasePart") then
                   local offset = cf.Position - part.Position
                   for _, p in ipairs(obj:GetDescendants()) do
                       if p:IsA("BasePart") then
                           p.CFrame = CFrame.new(p.Position + offset)
                       end
                   end
                   break
               end
           end
       end
   elseif obj:IsA("BasePart") then
       obj.CFrame = cf
   end
end

-- Restaure un objet à sa CFrame d'origine
local function restoreObject(obj, savedCF)
   if obj:IsA("Model") then
       if obj.PrimaryPart then
           obj:SetPrimaryPartCFrame(savedCF)
       else
           local firstPart = nil
           for _, p in ipairs(obj:GetDescendants()) do
               if p:IsA("BasePart") then firstPart = p; break end
           end
           if firstPart then
               local offset = savedCF.Position - firstPart.Position
               for _, p in ipairs(obj:GetDescendants()) do
                   if p:IsA("BasePart") then
                       p.CFrame = CFrame.new(p.Position + offset)
                   end
               end
           end
       end
   elseif obj:IsA("BasePart") then
       obj.CFrame = savedCF
   end
end

local function activateSetup(btn)
   -- Sol
   local floor = findFloor()
   if floor then
       originalFloorPos = floor.Position
       floor.Position = Vector3.new(963.71, 471.11, 439.59)
   end

   -- Armes
   originalWeaponCFrames = {}
   for _, weapon in ipairs(weaponList) do
       local obj = findInItemsOnSale(weapon.name)
       if obj then
           local cf = getObjectCFrame(obj)
           if cf then originalWeaponCFrames[weapon.name] = cf end
           pcall(moveWeapon, obj, weapon.pos)
       end
   end

   -- Gun Locker
   local gunLocker = findGunLocker()
   if gunLocker then
       local cf = getObjectCFrame(gunLocker)
       if cf then originalGunLockerCFrame = cf end
       pcall(moveObject, gunLocker, GUN_LOCKER_TARGET)
   end

   -- Crafting Station
   local crafting = findCraftingStation()
   if crafting then
       local cf = getObjectCFrame(crafting)
       if cf then originalCraftingCFrame = cf end
       pcall(moveObject, crafting, CRAFTING_TARGET)
   end

   -- Prizes (deux objets)
   local prize1, prize2 = findPrizes()
   if prize1 then
       local cf = getObjectCFrame(prize1)
       if cf then originalPrize1CFrame = cf end
       pcall(moveObject, prize1, PRIZE1_TARGET)
   end
   if prize2 then
       local cf = getObjectCFrame(prize2)
       if cf then originalPrize2CFrame = cf end
       pcall(moveObject, prize2, PRIZE2_TARGET)
   end

   setupActive = true
   btn.Text = "✅"
   btn.BackgroundColor3 = Color3.fromRGB(0, 180, 80)
end

local function deactivateSetup(btn)
   -- Sol
   local floor = findFloor()
   if floor and originalFloorPos then
       floor.Position = originalFloorPos
   end

   -- Armes
   for _, weapon in ipairs(weaponList) do
       local obj = findInItemsOnSale(weapon.name)
       local savedCF = originalWeaponCFrames[weapon.name]
       if obj and savedCF then
           pcall(restoreWeapon, obj, savedCF)
       end
   end
   originalWeaponCFrames = {}
   originalFloorPos = nil

   -- Gun Locker
   if originalGunLockerCFrame then
       local gunLocker = findGunLocker()
       if gunLocker then
           pcall(restoreObject, gunLocker, originalGunLockerCFrame)
       end
       originalGunLockerCFrame = nil
   end

   -- Crafting Station
   if originalCraftingCFrame then
       local crafting = findCraftingStation()
       if crafting then
           pcall(restoreObject, crafting, originalCraftingCFrame)
       end
       originalCraftingCFrame = nil
   end

   -- Prizes
   local prize1, prize2 = findPrizes()
   if originalPrize1CFrame and prize1 then
       pcall(restoreObject, prize1, originalPrize1CFrame)
       originalPrize1CFrame = nil
   end
   if originalPrize2CFrame and prize2 then
       pcall(restoreObject, prize2, originalPrize2CFrame)
       originalPrize2CFrame = nil
   end

   setupActive = false
   btn.Text = "⬜"
   btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
end

